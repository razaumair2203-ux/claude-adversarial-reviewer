{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "review_quality", "summary", "findings", "remaining_risks"],
  "properties": {
    "verdict": { "type": "string", "enum": ["approved", "revise"] },
    "review_quality": { "type": "string", "enum": ["valid", "degraded_content", "degraded_environmental"] },
    "summary": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "category", "location", "claim", "evidence", "recommended_action"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "high", "medium"] },
          "category": { "type": "string", "enum": ["correctness", "security", "data-loss", "scope", "testing", "architecture", "feasibility", "maintainability"] },
          "location": { "type": "string" },
          "claim": { "type": "string", "minLength": 1 },
          "evidence": { "type": "string", "minLength": 1 },
          "recommended_action": { "type": "string", "minLength": 1 }
        }
      }
    },
    "remaining_risks": { "type": "array", "items": { "type": "string" } }
  }
}

